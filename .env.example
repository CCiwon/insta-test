# Instagram Webhook 검증 토큰 (직접 설정하는 임의 문자열)
INSTAGRAM_VERIFY_TOKEN=your_verify_token_here

# Instagram Graph API 액세스 토큰
INSTAGRAM_ACCESS_TOKEN=your_access_token_here

# Instagram 앱 시크릿 (Webhook 서명 검증용)
INSTAGRAM_APP_SECRET=your_app_secret_here

# Instagram 유저 ID
INSTAGRAM_USER_ID=your_instagram_user_id_here

# OpenAI API 키
OPENAI_API_KEY=sk-...

# GPT 모델
OPENAI_MODEL=gpt-4o-mini

# AI 인플루언서 페르소나 (프롬프트에 주입)
ACCOUNT_PERSONA=친근하고 따뜻한 라이프스타일 인플루언서

# 정적 파일 공개 base URL (ngrok HTTPS URL 등)
PUBLIC_BASE_URL=https://xxxx.ngrok-free.app

# 기본 게시 이미지 파일명 (app/static/ 아래에 존재)
DEFAULT_IMAGE_FILENAME=post.jpg

# 기본 캡션
DEFAULT_CAPTION=안녕하세요! 오늘의 포스팅입니다 :)

# 관리자 API 키 (/publish/* 엔드포인트 인증용, 임의의 강력한 문자열로 설정)
ADMIN_API_KEY=your_strong_random_api_key_here

# 환경
ENV=development
